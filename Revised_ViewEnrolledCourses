import tkinter as tk
from tkinter import ttk, font
import os
from courses_backend import CourseManager

# ── Design tokens (from LMSCourseBrowser / "Other Code") ──────────────────────
BG_DARK         = "#F5EFE6"
BG_CARD         = "#FAF6F0"
BG_CARD2        = "#EDE5D8"
MAROON          = "#714329"
MAROON_DEEP     = "#4A2A18"
MAROON_LIGHT    = "#B08463"
GOLD_PALE       = "#FAF6F0"
GOLD_SUBTLE     = "#B9937B"
WHITE           = "#FAF6F0"
GRAY            = "#A08878"
GRAY_LIGHT      = "#7A6050"
BORDER          = "#D0B9A7"
BORDER_GOLD     = "#B08463"
TEXT_DARK       = "#3A2010"
TEXT_MID        = "#714329"
TEXT_LIGHT      = "#B9937B"
ACCENT          = "#714329"
ACCENT2         = "#B08463"
CHIP_BG         = "#D0B9A7"
CHIP_FG         = "#4A2A18"
BTN_BG          = "#714329"
BTN_FG          = "#FAF6F0"
BTN_HOV         = "#4A2A18"
NAV_BG          = "#3A2010"
NAV_FG          = "#D0B9A7"
NAV_ACTIVE_BG   = "#714329"
NAV_ACTIVE_FG   = "#FAF6F0"
